# Copy this file to .env and fill in your values.
# All variables are optional — the defaults work for local development.
# Never commit a .env file with real secrets.

# Model
EXTRACT_MODEL_NAME_OR_PATH=Qwen/Qwen2.5-0.5B-Instruct
EXTRACT_ADAPTER_PATH=./outputs/dpo/adapter
EXTRACT_USE_4BIT=true
EXTRACT_MAX_NEW_TOKENS=512

# Server
EXTRACT_HOST=0.0.0.0
EXTRACT_PORT=8000
EXTRACT_MAX_REQUEST_CHARS=8000
EXTRACT_MAX_CONCURRENCY=1
EXTRACT_INFERENCE_TIMEOUT_SECONDS=120.0

# Optional: set to 0 to disable model warm-up on startup
EXTRACT_ENABLE_WARMUP=true

# Optional: offline mode (no HuggingFace Hub calls)
# HF_HUB_OFFLINE=1

# Optional: W&B experiment tracking
# WANDB_PROJECT=structured-extraction-ft
# WANDB_API_KEY=your_key_here
